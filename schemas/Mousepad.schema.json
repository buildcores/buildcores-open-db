{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": ["object", "null"],
  "title": "Mousepad Schema",
  "description": "Schema for Mousepad components",
  "required": ["metadata"],
  "properties": {
    "opendb_id": {
      "type": ["string", "null"],
      "description": "Unique identifier for the document (UUID v4)"
    },
    "general_product_information": {
      "type": ["object", "null"],
      "description": "General product information and retailer SKUs",
      "properties": {
        "amazon_sku": {
          "type": ["string", "null"],
          "description": "Amazon product SKU"
        },
        "newegg_sku": {
          "type": ["string", "null"],
          "description": "Newegg product SKU"
        },
        "bestbuy_sku": {
          "type": ["string", "null"],
          "description": "Best Buy product SKU"
        },
        "walmart_sku": {
          "type": ["string", "null"],
          "description": "Walmart product SKU"
        },
        "adorama_sku": {
          "type": ["string", "null"],
          "description": "Adorama product SKU"
        },
        "ibuypower_sku": {
          "type": ["string", "null"],
          "description": "iBuyPower product SKU"
        },
        "hyte_sku": {
          "type": ["string", "null"],
          "description": "HYTE product SKU"
        },
        "manufacturer_url": {
          "type": ["string", "null"],
          "description": "Official manufacturer product URL"
        }
      }
    },
    "metadata": {
      "type": ["object", "null"],
      "properties": {
        "name": {
          "description": "Full product name",
          "type": ["string", "null"]
        },
        "manufacturer": {
          "description": "Mousepad manufacturer",
          "type": ["string", "null"]
        },
        "part_numbers": {
          "description": "Array of manufacturer's part numbers/SKUs",
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        },
        "series": {
          "description": "Product series name",
          "type": ["string", "null"]
        },
        "variant": {
          "description": "Specific variant in the series",
          "type": ["string", "null"]
        },
        "release_year": {
          "description": "Year of release",
          "type": ["integer", "null"]
        },
        "last_manually_spec_verified_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO 8601 timestamp of when the part specs were last manually verified by a human"
        }
      },
      "required": ["name"]
    }
  }
}
